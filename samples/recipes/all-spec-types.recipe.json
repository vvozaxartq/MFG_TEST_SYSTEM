{
  "name": "All Spec Types Recipe",
  "prefix": "dut",
  "scripts": [
    {
      "name": "ReadBatterySnapshot",
      "command": "READ_BATTERY_SNAPSHOT",
      "prefix": "battery",
      "measurements": [
        {
          "key": "voltage",
          "unit": "V",
          "description": "Battery voltage"
        },
        {
          "key": "current",
          "unit": "A",
          "description": "Battery current"
        }
      ],
      "simulatedResponse": "{\"voltage\":12.3,\"current\":1.4}"
    },
    {
      "name": "ReadDeviceInfo",
      "command": "READ_DEVICE_INFO",
      "measurements": [
        {
          "key": "serial",
          "description": "Device serial number"
        },
        {
          "key": "model",
          "description": "Device model name"
        },
        {
          "key": "station",
          "description": "Station identifier"
        },
        {
          "key": "error_state",
          "description": "Current error state"
        },
        {
          "key": "calibration",
          "description": "Calibration result"
        }
      ],
      "simulatedResponse": "{\"serial\":\"ATS-FAKE-001\",\"model\":\"MFG TEST SYSTEM\",\"station\":\"STATION-A\",\"error_state\":\"NONE\",\"calibration\":\"SKIPPED\"}"
    },
    {
      "name": "ReadEnvironment",
      "command": "READ_ENVIRONMENT",
      "prefix": "env",
      "measurements": [
        {
          "key": "temperature",
          "unit": "C",
          "description": "Measured temperature"
        },
        {
          "key": "leak_rate",
          "unit": "sccm",
          "description": "Measured leak rate"
        }
      ],
      "simulatedResponse": "{\"temperature\":35.5,\"leak_rate\":0.2}"
    }
  ]
}
