{
  "name": "Multi Measurement Specs",
  "rules": [
    {
      "name": "Battery Voltage Range",
      "targetKey": "battery.voltage",
      "ruleType": "Range",
      "min": 11.5,
      "max": 12.8,
      "errorCode": "BATTERY_VOLTAGE_RANGE"
    },
    {
      "name": "Battery Current Limit",
      "targetKey": "battery.current",
      "ruleType": "LessThan",
      "expected": "1.8",
      "errorCode": "BATTERY_CURRENT_LIMIT"
    },
    {
      "name": "Load Voltage Range",
      "targetKey": "load.voltage",
      "ruleType": "Range",
      "min": 11.0,
      "max": 12.0,
      "errorCode": "LOAD_VOLTAGE_RANGE"
    },
    {
      "name": "Load Current Limit",
      "targetKey": "load.current",
      "ruleType": "LessThan",
      "expected": "2.0",
      "errorCode": "LOAD_CURRENT_LIMIT"
    }
  ]
}
